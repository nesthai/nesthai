# ============================================
# BEAULIEU PROPERTY MANAGEMENT - REDIRECTIONS SEO
# ============================================

RewriteEngine On
RewriteBase /

# --- REDIRECTIONS 301 - Pages dupliquées ---
# Évite le contenu dupliqué pour Google

# Condo Panora (doublons → version canonique)
RewriteRule ^condo-axis\.html$ /condo-panora-estuaria.html [R=301,L]
RewriteRule ^condo-centric\.html$ /condo-panora-estuaria.html [R=301,L]
RewriteRule ^condo-panora\.html$ /condo-panora-estuaria.html [R=301,L]

# Wongamat (doublon → version canonique)
RewriteRule ^condo-wongamat\.html$ /condo-wongamat-tower.html [R=301,L]

# --- WWW vs non-WWW (choisir une version) ---
# Redirection vers www (décommenter si vous préférez www)
# RewriteCond %{HTTP_HOST} ^beaulieu-pattaya\.com$ [NC]
# RewriteRule ^(.*)$ https://www.beaulieu-pattaya.com/$1 [R=301,L]

# Redirection vers non-www (décommenter si vous préférez sans www)
RewriteCond %{HTTP_HOST} ^www\.beaulieu-pattaya\.com$ [NC]
RewriteRule ^(.*)$ https://beaulieu-pattaya.com/$1 [R=301,L]

# --- HTTPS forcé ---
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# --- TRAILING SLASH optionnel ---
# RewriteCond %{REQUEST_FILENAME} !-f
# RewriteRule ^(.*[^/])$ /$1/ [R=301,L]

# --- COMPRESSION GZIP ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/rss+xml application/json
</IfModule>

# --- CACHE NAVIGATEUR ---
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# --- PROTECTION FICHIERS SENSIBLES ---
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Désactiver l'affichage des répertoires
Options -Indexes